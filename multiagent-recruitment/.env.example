# ============================================================
# Multi-Agent Recruitment System — Environment Variables
# Copy this file to .env and fill in your keys.
# ============================================================

# ── Recruitment workflow LLM (main application) ─────────────
# The multi-agent workflow uses LangChain + OpenAI by default.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── DeepEval evaluation metrics (evaluation framework only) ─
# DeepEval metrics (Faithfulness, AnswerRelevancy, Hallucination, GEval)
# use OpenRouter so evaluation traffic never hits api.openai.com.
# Get your key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Model used by DeepEval metrics (OpenRouter model string).
# See full list at: https://openrouter.ai/models
# Default: openai/gpt-4o-mini
# OPENROUTER_EVAL_MODEL=openai/gpt-4o-mini

# ── Demo / development mode ──────────────────────────────────
# Set to "true" to run the workflow with deterministic stub responses
# (no real API calls, no API key required for the main workflow).
RECRUITMENT_DEMO_MODE=true

# ── Optional recruitment workflow overrides ──────────────────
# Override any setting via the RECRUITMENT_ prefix.
# RECRUITMENT_LLM_MODEL=gpt-4o-mini
# RECRUITMENT_LLM_TEMPERATURE=0.1
# RECRUITMENT_MAX_REVISION_COUNT=3
# RECRUITMENT_MAX_STEP_BUDGET=50
# RECRUITMENT_PASSING_SCORE=70.0
# RECRUITMENT_BORDERLINE_LOWER=50.0
# RECRUITMENT_BORDERLINE_UPPER=75.0
# RECRUITMENT_LOG_LEVEL=INFO
